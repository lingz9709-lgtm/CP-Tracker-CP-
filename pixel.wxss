.wrap {
  padding: 14px 14px 18px;
}

.card {
  background: rgba(0, 0, 0, 0.12);
  border: 1px solid rgba(92, 74, 42, 0.9);
  border-radius: 14px;
  padding: 12px;
  margin-bottom: 12px;
}

.title {
  font-weight: 900;
  letter-spacing: 0.14em;
  font-size: 12px;
  color: rgba(213, 198, 179, 0.92);
}

.sub {
  margin-bottom: 10px;
  font-weight: 900;
  letter-spacing: 0.12em;
  font-size: 11px;
  color: rgba(213, 198, 179, 0.76);
}

.row {
  margin-top: 12px;
  display: flex;
  gap: 10px;
}

.input {
  flex: 1;
  min-width: 0;
  border: 1px solid rgba(122, 101, 72, 0.9);
  background: rgba(68, 60, 46, 0.9);
  color: #d5c6b3;
  border-radius: 10px;
  padding: 10px 10px;
  font-size: 13px;
}

.input.small {
  flex: 0 0 92px;
}

.mode-picker {
  width: 100%;
}

.drag-tip {
  margin-top: 10px;
  color: rgba(213, 198, 179, 0.82);
  font-size: 10px;
  letter-spacing: 0.08em;
}

.uploads {
  margin-top: 12px;
  display: flex;
  gap: 10px;
  align-items: center;
}

.up {
  flex: 1;
  height: 160px;
  border: 2px dashed rgba(92, 74, 42, 0.9);
  border-radius: 14px;
  position: relative;
  overflow: hidden;
  background: rgba(0, 0, 0, 0.1);
}

.up-t {
  position: absolute;
  top: 8px;
  left: 10px;
  font-size: 10px;
  color: rgba(213, 198, 179, 0.75);
  z-index: 2;
}

.prev {
  width: 100%;
  height: 100%;
}

.drag-meta {
  position: absolute;
  right: 8px;
  bottom: 8px;
  z-index: 2;
  background: rgba(0, 0, 0, 0.45);
  color: rgba(255, 255, 255, 0.9);
  font-size: 9px;
  border-radius: 8px;
  padding: 2px 6px;
}

.ph {
  height: 160px;
  display: flex;
  align-items: center;
  justify-content: center;
  color: rgba(213, 198, 179, 0.65);
  letter-spacing: 0.08em;
}

.x {
  color: #ac211c;
  font-weight: 900;
  font-size: 18px;
}

.crop-box {
  margin-top: 10px;
  border: 1px solid rgba(92, 74, 42, 0.9);
  border-radius: 10px;
  padding: 8px 10px;
  background: rgba(0, 0, 0, 0.12);
}

.crop-title {
  color: rgba(213, 198, 179, 0.9);
  font-size: 10px;
  letter-spacing: 0.12em;
  margin-bottom: 4px;
}

.crop-row {
  color: rgba(213, 198, 179, 0.75);
  font-size: 9px;
  letter-spacing: 0.08em;
}

.btn {
  margin-top: 12px;
  background: #ac211c;
  color: white;
  border-radius: 10px;
  padding: 12px 14px;
  font-size: 12px;
  letter-spacing: 0.12em;
}

.btn.ghost {
  background: none;
  border: 1px solid rgba(122, 101, 72, 0.9);
  color: rgba(213, 198, 179, 0.85);
}
